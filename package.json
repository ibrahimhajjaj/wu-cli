{
  "name": "@ibrahimwithi/wu-cli",
  "version": "0.1.27",
  "type": "module",
  "description": "WhatsApp CLI tool — like gh is to GitHub, wu is to WhatsApp",
  "author": "Ibrahim Hajjaj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibrahimhajjaj/wu-cli.git"
  },
  "homepage": "https://github.com/ibrahimhajjaj/wu-cli",
  "keywords": [
    "whatsapp",
    "cli",
    "mcp",
    "baileys",
    "messaging"
  ],
  "bin": {
    "wu": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/lib.js",
    "./core/*": "./dist/core/*.js",
    "./db/*": "./dist/db/*.js",
    "./config/*": "./dist/config/*.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "better-sqlite3": "^12.6.2",
    "commander": "^13.1.0",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^10.6.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.1"
  }
}
